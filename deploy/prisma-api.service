[Unit]
Description=Prisma Mini App API (FastAPI)
After=network.target postgresql.service

[Service]
Type=simple
User=prisma
WorkingDirectory=/var/www/prisma/backend
ExecStart=/var/www/prisma/backend/.venv/bin/uvicorn app.api.main:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
