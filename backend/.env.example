# Telegram bot tokeni (@BotFather'dan olinadi)
BOT_TOKEN=123456:ABC-DEF...

# Bot username (@ belgisisiz) — taklif (referral) havolasi uchun
BOT_USERNAME=salesaireportdilraboisraolivabot

# Mini app manzili (Telegram'da ishlashi uchun HTTPS bo'lishi SHART)
WEBAPP_URL=https://example.com

# Qo'llab-quvvatlash uchun bog'lanish manzili ("Murojaat qilish" tugmasi)
SUPPORT_URL=https://t.me/salesaireportdilraboisraolivabot

# Pastki menyu tugmasi yozuvi
MENU_BUTTON_TEXT=Sotuv va Audit

# PostgreSQL ulanish manzili (asyncpg drayveri bilan)
DATABASE_URL=postgresql+asyncpg://prisma:parol@localhost:5432/prisma

# API sozlamalari
API_HOST=0.0.0.0
API_PORT=8000

# CORS — frontend manzillari (JSON ro'yxat)
CORS_ORIGINS=["http://localhost:5173","https://example.com"]

# Admin Telegram ID lari (JSON ro'yxat)
ADMIN_IDS=[123456789]

# Test rejimi — Telegram'siz (brauzerda) ham ishlaydi. Prod'da false qiling.
DEV_AUTH_BYPASS=false

# === minds.abdulvahob-blog.uz — tashqi to'lov/obuna backend'i ===
